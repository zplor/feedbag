{
  "name": "feedbag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "feedbag - local file packer for AI",
  "scripts": {
    "build": "turbo build",
    "dev": "cross-env __DEV__=true vite --mode development",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "check:fix": "biome check --write .",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "clean:dist": "turbo clean"
  },
  "dependencies": {
    "antd": "^5.28.0",
    "deepmerge": "^4.3.1",
    "i18next": "^23.10.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.561.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^14.1.0",
    "react-router-dom": "^6.27.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "postcss": "^8.5.3",
    "postcss-load-config": "^6.0.1",
    "rimraf": "^6.0.1",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "turbo": "^2.7.5",
    "typescript": "~5.6.2",
    "vite": "^5.4.9"
  },
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "author": "Zplor",
  "license": "MIT",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  },
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  }
}
